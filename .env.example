NODE_ENV=development
APP_NAME=ddd-nestjs-template
APP_VERSION=0.0.1
PORT=3000
DEBUG=false
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_INCLUDE_STACK=true
LOG_REDACT_PATHS=req.headers.authorization,req.headers.cookie,res.headers["set-cookie"],password,token,accessToken,refreshToken

# Sentry (tracing + errores). Sin SENTRY_DSN el SDK no se inicializa.
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENABLE_LOGS=true
